# ─────────────────────────────────────────────────────────────────────────────
# Tradie CRM — environment variables
#
# Copy this file to .env.local and fill in the real values.
# .env.local is git-ignored; this file is safe to commit.
#
# Where to find these values:
#   Supabase Dashboard → your project → Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL  (e.g. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The canonical public URL of this deployment — used to build auth redirect URLs.
# Must match the "Site URL" in Supabase → Authentication → URL Configuration.
# Local dev: http://localhost:3000
# Production: https://tradie-crm.vercel.app
NEXT_PUBLIC_SITE_URL=
